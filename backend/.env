# =====================================================
# DEVELOPMENT ENVIRONMENT (.env)
# =====================================================

# Database
POSTGRES_USER=ebike_user
POSTGRES_PASSWORD=password@123
POSTGRES_DB=ebike_db
POSTGRES_PORT=5432
POSTGRES_BACKUP_PATH=/var/lib/postgresql/backup

# Redis
REDIS_PASSWORD=redis_password_123
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# Application
SERVER_PORT=8080
CONTEXT_PATH=/api/v1
ENVIRONMENT=development
SPRING_PROFILES_ACTIVE=dev

# JWT
JWT_SECRET=your-secret-key-here-minimum-256-bits-required-for-security
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_DATABASE=ebike_chatbot

# ML Models
ML_MODELS_PATH=/app/ml-models
BERT_MODEL_PATH=/app/ml-models/intent-classifier.pkl
NER_MODEL_PATH=/app/ml-models/entity-extractor.pkl

# Chatbot
CHATBOT_MAX_TURNS=5
CHATBOT_SIMILARITY_THRESHOLD=0.7
CHATBOT_FAQ_ENABLED=true

# Logging
LOG_LEVEL=DEBUG
LOG_FILE_PATH=/app/logs/app.log