{
  "models": {
    "intent_classifier": {
      "name": "BERT Intent Classifier",
      "version": "1.0.0",
      "path": "intent-classifier.pkl",
      "framework": "transformers",
      "model_type": "bert-base-uncased",
      "classes": [
        "search_product",
        "check_price",
        "check_order_status",
        "get_recommendation",
        "complaint"
      ]
    },
    "entity_extractor": {
      "name": "NER Entity Extractor",
      "version": "1.0.0",
      "path": "entity-extractor.pkl",
      "framework": "transformers",
      "model_type": "bert-base-multilingual-cased",
      "entity_types": [
        "PRODUCT",
        "PRICE",
        "ORDER_ID",
        "DATE"
      ]
    }
  }
}