        <mxCell id="legend" value="Legend: PK = primary key, FK = foreign key, UNIQUE = unique constraint. Lines show main foreign-key relationships from Flyway migrations V2_0_0 to V2_0_2." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=13;fontStyle=1;" vertex="1" parent="1">
