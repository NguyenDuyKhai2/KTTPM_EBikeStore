<mxfile host="app.diagrams.net">
  <diagram name="Database ERD - E-Bike Multiplatform">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Database ERD - E-Bike Multiplatform" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="560" y="20" width="680" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="auth_schema" value="Schema: ebike_auth" style="swimlane;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=16;fontStyle=1;startSize=34;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="520" height="455" as="geometry"/>
        </mxCell>
        <mxCell id="users" value="users&#xa;PK id BIGSERIAL&#xa;username UNIQUE&#xa;email UNIQUE&#xa;password_hash&#xa;first_name, last_name&#xa;is_active, is_verified&#xa;created_at, updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;fontStyle=1;" vertex="1" parent="auth_schema">
          <mxGeometry x="25" y="55" width="210" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="roles" value="roles&#xa;PK id SERIAL&#xa;name UNIQUE&#xa;description" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;fontStyle=1;" vertex="1" parent="auth_schema">
          <mxGeometry x="285" y="55" width="200" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="permissions" value="permissions&#xa;PK id SERIAL&#xa;code UNIQUE&#xa;name&#xa;module_name&#xa;action_name" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=12;fontStyle=1;" vertex="1" parent="auth_schema">
          <mxGeometry x="285" y="155" width="200" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="user_roles" value="user_roles&#xa;PK user_id, role_id&#xa;FK user_id -&gt; users.id&#xa;FK role_id -&gt; roles.id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=12;" vertex="1" parent="auth_schema">
          <mxGeometry x="25" y="210" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="role_permissions" value="role_permissions&#xa;PK role_id, permission_id&#xa;FK role_id -&gt; roles.id&#xa;FK permission_id -&gt; permissions.id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=12;" vertex="1" parent="auth_schema">
          <mxGeometry x="285" y="275" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="user_permissions" value="user_permissions&#xa;PK id BIGSERIAL&#xa;FK user_id -&gt; users.id&#xa;FK permission_id -&gt; permissions.id&#xa;granted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=12;" vertex="1" parent="auth_schema">
          <mxGeometry x="25" y="320" width="210" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="authentication_logs" value="authentication_logs&#xa;PK id BIGSERIAL&#xa;FK user_id -&gt; users.id&#xa;login_time, logout_time&#xa;ip_address, user_agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#2563EB;fontSize=12;" vertex="1" parent="auth_schema">
          <mxGeometry x="285" y="390" width="200" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="product_schema" value="Schema: ebike_product" style="swimlane;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;fontSize=16;fontStyle=1;startSize=34;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="545" height="575" as="geometry"/>
        </mxCell>
        <mxCell id="categories" value="categories&#xa;PK id SERIAL&#xa;name UNIQUE&#xa;slug UNIQUE&#xa;description&#xa;is_active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;fontStyle=1;" vertex="1" parent="product_schema">
          <mxGeometry x="25" y="55" width="210" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="products" value="products&#xa;PK id BIGSERIAL&#xa;FK category_id -&gt; categories.id&#xa;name, slug UNIQUE&#xa;price, discount_price&#xa;stock_quantity&#xa;rating, review_count&#xa;is_featured, is_active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=12;fontStyle=1;" vertex="1" parent="product_schema">
          <mxGeometry x="285" y="55" width="225" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="reviews" value="reviews&#xa;PK id BIGSERIAL&#xa;FK product_id -&gt; products.id&#xa;FK user_id -&gt; users.id&#xa;rating, title, comment&#xa;UNIQUE product_id, user_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=12;" vertex="1" parent="product_schema">
          <mxGeometry x="25" y="185" width="210" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="product_specifications" value="product_specifications&#xa;PK id BIGSERIAL&#xa;FK product_id -&gt; products.id UNIQUE&#xa;model_code, brand&#xa;vehicle_type, battery_type&#xa;speed/range/motor/brake specs&#xa;warranty_months" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=12;" vertex="1" parent="product_schema">
          <mxGeometry x="285" y="225" width="225" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="product_variants" value="product_variants&#xa;PK id BIGSERIAL&#xa;FK product_id -&gt; products.id&#xa;sku UNIQUE&#xa;variant_name&#xa;color_name, color_hex&#xa;additional_price, stock_quantity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=12;" vertex="1" parent="product_schema">
          <mxGeometry x="25" y="335" width="210" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="product_images" value="product_images&#xa;PK id BIGSERIAL&#xa;FK product_id -&gt; products.id&#xa;FK variant_id -&gt; product_variants.id&#xa;image_url, alt_text&#xa;storage_provider LOCAL/S3&#xa;s3_key, status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#16A34A;fontSize=12;" vertex="1" parent="product_schema">
          <mxGeometry x="285" y="390" width="225" height="125" as="geometry"/>
        </mxCell>

        <mxCell id="order_schema" value="Schema: ebike_order" style="swimlane;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=16;fontStyle=1;startSize=34;" vertex="1" parent="1">
          <mxGeometry x="40" y="595" width="730" height="455" as="geometry"/>
        </mxCell>
        <mxCell id="showrooms" value="showrooms&#xa;PK id BIGSERIAL&#xa;name, city, district&#xa;address, phone&#xa;opening_hours, is_active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=12;fontStyle=1;" vertex="1" parent="order_schema">
          <mxGeometry x="25" y="55" width="210" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="orders" value="orders&#xa;PK id BIGSERIAL&#xa;FK user_id -&gt; users.id NULL for guest&#xa;FK cancellation_requested_by -&gt; users.id&#xa;order_number UNIQUE&#xa;status, subtotal, total_amount&#xa;registration_fee&#xa;cancellation fields&#xa;customer_email, identity_number" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#EA580C;fontSize=12;fontStyle=1;" vertex="1" parent="order_schema">
          <mxGeometry x="270" y="55" width="245" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="order_items" value="order_items&#xa;PK id BIGSERIAL&#xa;FK order_id -&gt; orders.id&#xa;FK product_id -&gt; products.id&#xa;FK product_variant_id -&gt; product_variants.id&#xa;product_name, unit_price&#xa;quantity, line_total" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=12;" vertex="1" parent="order_schema">
          <mxGeometry x="25" y="225" width="245" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="payments" value="payments&#xa;PK id BIGSERIAL&#xa;FK order_id -&gt; orders.id UNIQUE&#xa;payment_method, payment_status&#xa;transaction_reference UNIQUE nullable&#xa;amount, currency&#xa;VNPay provider fields&#xa;paid_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=12;" vertex="1" parent="order_schema">
