        <mxCell id="user_schema" value="Schema: ebike_user" style="swimlane;whiteSpace=wrap;html=1;fillColor=#FDF2F8;strokeColor=#DB2777;fontSize=16;fontStyle=1;startSize=34;" vertex="1" parent="1">
