        <mxCell id="chatbot_schema" value="Schema: ebike_chatbot" style="swimlane;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=16;fontStyle=1;startSize=34;" vertex="1" parent="1">
