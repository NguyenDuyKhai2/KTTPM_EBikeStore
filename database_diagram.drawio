        </mxCell>
        <mxCell id="shipments" value="shipments&#xa;PK id BIGSERIAL&#xa;FK order_id -&gt; orders.id UNIQUE&#xa;FK pickup_showroom_id -&gt; showrooms.id&#xa;shipment_status&#xa;recipient/shipping fields&#xa;tracking_number" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=12;" vertex="1" parent="order_schema">
          <mxGeometry x="540" y="210" width="165" height="130" as="geometry"/>
