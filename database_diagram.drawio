        <mxCell id="chatbot_note" value="No baseline tables yet&#xa;Reserved for chatbot data/history&#xa;Current chatbot uses FAQ/PDF resources and product data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=12;" vertex="1" parent="chatbot_schema">
